</div>

<script>
function closePopup(){document.getElementById('popup-bg').style.display='none'}

function openMenu(){
  document.getElementById('side-menu').classList.add('open');
  document.getElementById('menu-overlay').style.display='block';
}
function closeMenu(){
  document.getElementById('side-menu').classList.remove('open');
  document.getElementById('menu-overlay').style.display='none';
}

function goTo(page){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.side-menu nav a').forEach(a=>a.classList.remove('active'));
  document.getElementById('page-'+page).classList.add('active');
  document.getElementById('nav-'+page).classList.add('active');
  closeMenu();
  window.scrollTo(0,0);
}

function toggleLogin(){
  var o=document.getElementById('login-overlay');
  o.style.display=o.style.display==='flex'?'none':'flex';
}

function toggleFaq(el){
  var a=el.nextElementSibling;
  var icon=el.querySelector('i');
  a.classList.toggle('open');
  icon.style.transform=a.classList.contains('open')?'rotate(180deg)':'rotate(0)';
}

var currentCategory='';

function calcBMI(){
  var weight=parseFloat(document.getElementById('weight').value);
  var height=parseFloat(document.getElementById('height').value);
  if(!weight||!height){alert('Vul je lengte en gewicht in!');return;}
  var h=height/100;
  var bmi=weight/(h*h);
  var bmiR=Math.round(bmi*10)/10;

  document.getElementById('res-number').textContent=bmiR.toFixed(1);
  document.getElementById('result-box').style.display='block';

  var badge=document.getElementById('res-badge');
  var bar=document.getElementById('bmi-bar');
  var tip=document.getElementById('res-tip');
  var pct=Math.min(Math.max((bmi-10)/30*100,2),98);
  bar.style.width=pct+'%';

  if(bmi<18.5){
    currentCategory='onder';
    badge.textContent='Ondergewicht';
    badge.style.background='#E6F1FB';badge.style.color='#0C447C';
    bar.style.background='#378ADD';
    tip.textContent='Je BMI wijst op ondergewicht.';
  }else if(bmi<25){
    currentCategory='normaal';
    badge.textContent='Normaal gewicht';
    badge.style.background='#EAF3DE';badge.style.color='#27500A';
    bar.style.background='#639922';
    tip.textContent='Je BMI valt binnen het gezonde bereik.';
  }else if(bmi<30){
    currentCategory='over';
    badge.textContent='Overgewicht';
    badge.style.background='#FAEEDA';badge.style.color='#633806';
    bar.style.background='#BA7517';
    tip.textContent='Je hebt licht overgewicht.';
  }else{
    currentCategory='obese';
    badge.textContent='Obesitas';
    badge.style.background='#FCEBEB';badge.style.color='#791F1F';
    bar.style.background='#E24B4A';
    tip.textContent='Je BMI wijst op obesitas.';
  }
}

function scrollToUitleg(){
  var target=document.getElementById('uitleg-'+currentCategory);
  if(!target)return;
  target.scrollIntoView({behavior:'smooth',block:'start'});
  target.style.outline='2px solid #639922';
  target.style.outlineOffset='4px';
  setTimeout(function(){target.style.outline='none'},2000);
}
</script>
