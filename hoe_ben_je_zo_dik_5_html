<!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Hoe ben je zo dik?</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:system-ui,sans-serif;background:#f7fbf2;color:#1a2e0a;min-height:100vh}

/* POPUP */
.popup-bg{position:fixed;inset:0;background:rgba(0,0,0,0.45);backdrop-filter:blur(4px);z-index:999;display:flex;align-items:center;justify-content:center;padding:1rem}
.popup{background:#fff;border-radius:14px;border:1px solid #C0DD97;padding:2rem 2rem 1.5rem;max-width:360px;width:100%;text-align:center;position:relative}
.popup-close{position:absolute;top:12px;right:12px;background:none;border:none;cursor:pointer;color:#639922;font-size:20px;line-height:1;padding:4px}
.popup-close:hover{color:#27500A}
.popup-icon{width:56px;height:56px;border-radius:50%;background:#EAF3DE;border:2px solid #C0DD97;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem}
.popup-icon i{font-size:26px;color:#3B6D11}
.popup h2{font-size:20px;font-weight:600;color:#27500A;margin-bottom:0.5rem}
.popup p{font-size:15px;color:#3B6D11;margin-bottom:1.5rem;line-height:1.6}
.popup-btn{width:100%;padding:10px;border-radius:8px;border:none;background:#639922;color:#fff;font-size:15px;font-weight:500;cursor:pointer}
.popup-btn:hover{background:#3B6D11}

/* TOPBAR */
.topbar{background:#3B6D11;width:100%;display:flex;align-items:center;justify-content:space-between;padding:0 1.5rem;height:58px;position:sticky;top:0;z-index:100}
.topbar-left{display:flex;align-items:center;gap:12px}
.menu-btn{background:none;border:none;cursor:pointer;color:#fff;display:flex;flex-direction:column;gap:5px;padding:4px;justify-content:center}
.menu-btn span{display:block;width:22px;height:2px;background:#fff;border-radius:2px;transition:all 0.2s}
.topbar-logo{display:flex;align-items:center;gap:8px}
.logo-circle{width:36px;height:36px;border-radius:50%;background:rgba(255,255,255,0.15);display:flex;align-items:center;justify-content:center;border:1.5px solid rgba(255,255,255,0.3)}
.logo-circle i{font-size:18px;color:#fff}
.topbar-title{font-size:16px;font-weight:600;color:#fff}
.login-btn{display:flex;align-items:center;gap:6px;padding:7px 14px;border-radius:8px;border:1.5px solid rgba(255,255,255,0.4);background:transparent;color:#fff;font-size:13px;cursor:pointer;font-weight:500}
.login-btn:hover{background:rgba(255,255,255,0.15)}
.login-btn i{font-size:15px}

/* SIDE MENU */
.menu-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.35);z-index:200;display:none}
.side-menu{position:fixed;top:0;left:-280px;width:260px;height:100%;background:#fff;border-right:1px solid #C0DD97;z-index:201;transition:left 0.25s ease;display:flex;flex-direction:column}
.side-menu.open{left:0}
.side-menu-header{background:#3B6D11;padding:1.25rem 1.25rem 1rem;display:flex;align-items:center;gap:10px}
.side-menu-header .logo-circle{border-color:rgba(255,255,255,0.3)}
.side-menu-title{font-size:15px;font-weight:600;color:#fff}
.side-menu-close{margin-left:auto;background:none;border:none;cursor:pointer;color:#fff;font-size:22px;line-height:1}
.side-menu nav{padding:1rem 0;flex:1}
.side-menu nav a{display:flex;align-items:center;gap:12px;padding:13px 1.5rem;color:#27500A;font-size:15px;font-weight:500;text-decoration:none;border-left:3px solid transparent;transition:all 0.15s}
.side-menu nav a:hover,.side-menu nav a.active{background:#EAF3DE;border-left-color:#639922;color:#3B6D11}
.side-menu nav a i{font-size:18px;color:#639922}

/* PAGES */
.page{display:none;max-width:680px;margin:0 auto;padding:2rem 1.25rem}
.page.active{display:block}

/* SECTIONS */
.section{background:#fff;border:1px solid #C0DD97;border-radius:12px;padding:1.5rem;margin-bottom:1.5rem}
.section-title{font-size:17px;font-weight:600;color:#27500A;margin-bottom:0.75rem;display:flex;align-items:center;gap:8px}
.section-title i{font-size:20px;color:#639922}
.section p{font-size:14px;color:#3B6D11;line-height:1.7}

/* BMI FORM */
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
.field{display:flex;flex-direction:column;gap:5px}
.field label{font-size:13px;color:#3B6D11;font-weight:500}
.field input,.field select{padding:9px 12px;border-radius:8px;border:1px solid #C0DD97;background:#fff;color:#27500A;font-size:15px;outline:none}
.field input:focus,.field select:focus{border-color:#639922;box-shadow:0 0 0 3px rgba(99,153,34,0.15)}
.calc-btn{margin-top:1.25rem;width:100%;padding:11px;border-radius:8px;border:none;background:#639922;color:#fff;font-size:15px;font-weight:500;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px}
.calc-btn:hover{background:#3B6D11}

/* RESULT */
.result-box{display:none;background:#EAF3DE;border:1px solid #C0DD97;border-radius:10px;padding:1.25rem;margin-top:1.25rem}
.result-bmi{font-size:48px;font-weight:600;color:#27500A;line-height:1}
.result-sub{font-size:13px;color:#639922;margin-bottom:1rem}
.result-badge{display:inline-block;padding:4px 14px;border-radius:8px;font-size:13px;font-weight:600;margin-bottom:1rem}
.bmi-bar-wrap{height:10px;border-radius:5px;background:#C0DD97;overflow:hidden;margin-bottom:5px}
.bmi-bar{height:100%;border-radius:5px;transition:width 0.6s ease}
.bmi-scale{display:flex;justify-content:space-between;font-size:11px;color:#639922;margin-bottom:1rem}
.result-tip{font-size:13px;color:#27500A;line-height:1.6}
.meer-info-link{display:inline-block;margin-top:6px;font-size:13px;color:#3B6D11;font-weight:600;text-decoration:underline;cursor:pointer}
.meer-info-link:hover{color:#27500A}

/* UITLEG BLOCKS */
.uitleg-block{border-radius:10px;padding:1.1rem 1.25rem;margin-bottom:1rem;border:1px solid}
.uitleg-block h3{font-size:14px;font-weight:600;margin-bottom:0.4rem}
.uitleg-block p{font-size:13px;line-height:1.65}
.uitleg-block.onder{background:#E6F1FB;border-color:#B5D4F4;color:#0C447C}
.uitleg-block.normaal{background:#EAF3DE;border-color:#C0DD97;color:#27500A}
.uitleg-block.over{background:#FAEEDA;border-color:#FAC775;color:#633806}
.uitleg-block.obese{background:#FCEBEB;border-color:#F7C1C1;color:#791F1F}

/* FAQ */
.faq-item{border-bottom:1px solid #C0DD97;padding:1rem 0}
.faq-item:last-child{border-bottom:none}
.faq-q{font-size:14px;font-weight:600;color:#27500A;cursor:pointer;display:flex;justify-content:space-between;align-items:center;gap:8px}
.faq-q i{font-size:16px;color:#639922;transition:transform 0.2s;flex-shrink:0}
.faq-a{font-size:13px;color:#3B6D11;line-height:1.7;margin-top:0.6rem;display:none}
.faq-a.open{display:block}

/* CONTACT */
.contact-row{display:flex;align-items:center;gap:12px;padding:0.9rem 0;border-bottom:1px solid #EAF3DE;font-size:14px;color:#27500A}
.contact-row:last-child{border-bottom:none}
.contact-row i{font-size:20px;color:#639922;flex-shrink:0}
.contact-label{font-size:12px;color:#639922;font-weight:500}
.contact-form .field{margin-bottom:0.75rem}
.contact-form textarea{width:100%;padding:9px 12px;border-radius:8px;border:1px solid #C0DD97;background:#fff;color:#27500A;font-size:14px;outline:none;resize:vertical;min-height:100px;font-family:inherit}
.contact-form textarea:focus{border-color:#639922;box-shadow:0 0 0 3px rgba(99,153,34,0.15)}

/* LOGIN MODAL */
.login-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.4);backdrop-filter:blur(3px);z-index:300;display:none;align-items:center;justify-content:center}
.login-modal{background:#fff;border:1px solid #C0DD97;border-radius:12px;padding:1.75rem;width:300px;position:relative}
.login-modal h3{font-size:16px;font-weight:600;color:#27500A;margin-bottom:1rem;display:flex;align-items:center;gap:8px}
.login-modal h3 i{color:#639922;font-size:18px}
.lm-close{position:absolute;top:12px;right:12px;background:none;border:none;cursor:pointer;color:#639922;font-size:20px}
.login-modal .field{margin-bottom:0.75rem}
.login-actions{display:flex;gap:8px;margin-top:1rem}
.login-actions button{flex:1;padding:9px;border-radius:8px;border:1px solid #C0DD97;background:#fff;color:#27500A;font-size:14px;cursor:pointer;font-weight:500}
.login-actions button:hover{background:#EAF3DE}
.login-actions button.primary{background:#639922;color:#fff;border:none}
.login-actions button.primary:hover{background:#3B6D11}

@media(max-width:480px){.form-grid{grid-template-columns:1fr}.topbar-title{font-size:14px}}
</style>
</head>
<body>

<!-- POPUP -->
<div class="popup-bg" id="popup-bg">
  <div class="popup">
    <button class="popup-close" onclick="closePopup()" aria-label="Sluiten"><i class="ti ti-x"></i></button>
    <div class="popup-icon"><i class="ti ti-alert-circle"></i></div>
    <h2>Let op!</h2>
